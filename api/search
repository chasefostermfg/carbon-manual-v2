d routes under x+/ prefix"},"266":{"id":"/concepts/overview-59","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#routing","content":"Public routes under _public+/ prefix"},"267":{"id":"/concepts/overview-60","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#routing","content":"API routes under api+/ prefix"},"268":{"id":"/concepts/overview-61","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#routing","content":"File serving routes under file+/ prefix"},"269":{"id":"/concepts/overview-62","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#routing","content":"External/shared routes under share+/ prefix"},"270":{"id":"/concepts/overview-63","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#path-configuration","content":"In /apps/erp/app/utils/path.ts:"},"271":{"id":"/concepts/overview-64","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#path-configuration","content":"path.to.externalQuote(id) generates /share/quote/${id}"},"272":{"id":"/concepts/overview-65","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#path-configuration","content":"Quote sharing implemented in QuoteHeader.tsx using window.location.origin + path.to.externalQuote(externalLinkId)"},"273":{"id":"/concepts/overview-66","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#services","content":"Each module defines a set of methods for interacting with the module. The convention is to have at least four methods for each table."},"274":{"id":"/concepts/overview-67","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#services","content":"deleteCustomerPortal() - Delete customer portal link"},"275":{"id":"/concepts/overview-68","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#services","content":"getCustomerPortals() - List customer portal links"},"276":{"id":"/concepts/overview-69","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#services","content":"getCustomerPortal() - Get specific customer portal"},"277":{"id":"/concepts/overview-70","page_id":"/concepts/overview","tags":[],"type":"text","url":"/concepts/overview#services","content":"upsertCustomerPortal() - Create/update customer portal"},"278":{"id":"/concepts/permissions","page_id":"/concepts/permissions","type":"page","content":"Permissions","breadcrumbs":["Framework","Concepts"],"tags":[],"url":"/concepts/permissions"},"279":{"id":"/concepts/permissions-0","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"Learn about the permissions system in Carbon"},"280":{"id":"/concepts/permissions-1","page_id":"/concepts/permissions","type":"heading","tags":[],"url":"/concepts/permissions#permissions-in-the-code","content":"Permissions in the Code"},"281":{"id":"/concepts/permissions-2","page_id":"/concepts/permissions","type":"heading","tags":[],"url":"/concepts/permissions#database-row-level-security","content":"Database Row-Level Security"},"282":{"id":"/concepts/permissions-3","page_id":"/concepts/permissions","type":"heading","tags":[],"url":"/concepts/permissions#server-side-permission-checks","content":"Server-Side Permission Checks"},"283":{"id":"/concepts/permissions-4","page_id":"/concepts/permissions","type":"heading","tags":[],"url":"/concepts/permissions#client-side-permission-checks","content":"Client-Side Permission Checks"},"284":{"id":"/concepts/permissions-5","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"There are two types of permissions in the system:"},"285":{"id":"/concepts/permissions-6","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"Module permissions - These are permissions that are specific to a module. For example, a user may have permission to view the sales module, but not to create, update or delete sales."},"286":{"id":"/concepts/permissions-7","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"Role permissions - These are permissions that are specific to a role. For example, customers may be able to view the sales module, but a customer role limits the data to only their own sales, where an employee with the same permission can view all sales."},"287":{"id":"/concepts/permissions-8","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"A user's permissions are stored in the userPermissions table and the role is stored in the auth.users table in the raw_app_meta_data column."},"288":{"id":"/concepts/permissions-9","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"The JSON permissions data in that column something like this:"},"289":{"id":"/concepts/permissions-10","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"Each user has a role, which may be one of the following:"},"290":{"id":"/concepts/permissions-11","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"employee"},"291":{"id":"/concepts/permissions-12","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"customer"},"292":{"id":"/concepts/permissions-13","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"supplier"},"293":{"id":"/concepts/permissions-14","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"Additionally, each user has a set of permissions for each module. Generally, the permissions are:"},"294":{"id":"/concepts/permissions-15","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"<module>_view"},"295":{"id":"/concepts/permissions-16","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"<module>_create"},"296":{"id":"/concepts/permissions-17","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"<module>_update"},"297":{"id":"/concepts/permissions-18","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"<module>_delete"},"298":{"id":"/concepts/permissions-19","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"Permissions are managed within the user module. An employee's permissions are set according to the default permissions for their employee type when the user is created. Each employee may then be fine-tuned for individual permissions in the users module. There is also an option to bulk update permissions for employees."},"299":{"id":"/concepts/permissions-20","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions","content":"Currently, all customers and suppliers have hard-coded permissions, which are set when the customer account or supplier account is created."},"300":{"id":"/concepts/permissions-21","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#permissions-in-the-code","content":"There are three places where permissions can be used in the code. In order of precedence, they are:"},"301":{"id":"/concepts/permissions-22","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#permissions-in-the-code","content":"Database row-level security (RLS) - an in-database policy, written in SQL, that limits the data that a user can see or modify."},"302":{"id":"/concepts/permissions-23","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#permissions-in-the-code","content":"Server-side permission checks - a helper function that checks the user's permissions before making a call to the database."},"303":{"id":"/concepts/permissions-24","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#permissions-in-the-code","content":"Client-side permission checks - a helper function that checks the user's permissions before making a call to the server."},"304":{"id":"/concepts/permissions-25","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#permissions-in-the-code","content":"It is most important to use RLS. But server-side and client-side mechanisms can be used as additional security measures. RLS is expensive, so we use server-side and client-side checks to avoid making unnecessary calls to the database."},"305":{"id":"/concepts/permissions-26","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#database-row-level-security","content":"Here is an example of how to use RLS policies to limit a user's rights to modify a table using the get_my_claim function. This is SQL that's run against the database to create a security policy for the customer table. If you're not familiar with the ::bolean and ::jsonb syntax, that's just casting the value to a boolean or jsonb type. The get_my_claim function is a custom function that returns the value of a claim from the user's permissions record. The auth.uid() function returns the user's ID."},"306":{"id":"/concepts/permissions-27","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#server-side-permission-checks","content":"We provide a helper function called requirePermissions that can be used to check the user's permissions before making a call to the database. This method is almost always called in an action (data write) or a loader (data fetch)."},"307":{"id":"/concepts/permissions-28","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#server-side-permission-checks","content":"Here is an example of how to use it in a loader:"},"308":{"id":"/concepts/permissions-29","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#server-side-permission-checks","content":"In this example, the user must have the sales_view permission and the employee role in order to access the loader. If the user does not have the required permissions, an Access denied error will be thrown, and the user will be redirected to the root page."},"309":{"id":"/concepts/permissions-30","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#server-side-permission-checks","content":"We can also required multiple permissions. In the next example, the user must have the sales_update permission and the users_update permission in order to invoke the action:"},"310":{"id":"/concepts/permissions-31","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#client-side-permission-checks","content":"Finally, we can use client-side permission checks to limit what the user can do in the UI. This is done using the usePermissions hook. It provides two methods:"},"311":{"id":"/concepts/permissions-32","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#client-side-permission-checks","content":"can - a function that takes a module (sales) and an action (view, create, update, delete) and returns a boolean indicating whether the user has the required permission."},"312":{"id":"/concepts/permissions-33","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#client-side-permission-checks","content":"is - a function that takes a role (employee, customer, supplier) and returns a boolean indicating whether the user has the required role."},"313":{"id":"/concepts/permissions-34","page_id":"/concepts/permissions","tags":[],"type":"text","url":"/concepts/permissions#client-side-permission-checks","content":"Here's an example of how we might use client-side permission checks to hide the NewSalesForm component if the user does not have the sales_create permission:"},"314":{"id":"/concepts/principles","page_id":"/concepts/principles","type":"page","content":"Principles","tags":[],"url":"/concepts/principles"},"315":{"id":"/concepts/principles-0","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles","content":"The principles that guide the development of Carbon"},"316":{"id":"/concepts/principles-1","page_id":"/concepts/principles","type":"heading","tags":[],"url":"/concepts/principles#simplicity","content":"Simplicity"},"317":{"id":"/concepts/principles-2","page_id":"/concepts/principles","type":"heading","tags":[],"url":"/concepts/principles#extensibility","content":"Extensibility"},"318":{"id":"/concepts/principles-3","page_id":"/concepts/principles","type":"heading","tags":[],"url":"/concepts/principles#openness","content":"Openness"},"319":{"id":"/concepts/principles-4","page_id":"/concepts/principles","type":"heading","tags":[],"url":"/concepts/principles#productivity","content":"Productivity"},"320":{"id":"/concepts/principles-5","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles","content":"Decision-making is guided by four principles:"},"321":{"id":"/concepts/principles-6","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles","content":"Simplicity"},"322":{"id":"/concepts/principles-7","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles","content":"Extensibility"},"323":{"id":"/concepts/principles-8","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles","content":"Openness"},"324":{"id":"/concepts/principles-9","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles","content":"Productivity"},"325":{"id":"/concepts/principles-10","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#simplicity","content":"We understand that manufacturers don't often have the luxury of large teams of developers. Often a single software developer will be responsible for many custom applications. Our goal is to provide a simple platform with a single database that manufacturers can use as the heart of their digital operations."},"326":{"id":"/concepts/principles-11","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#simplicity","content":"To provide simplicity we use these approaches:"},"327":{"id":"/concepts/principles-12","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#simplicity","content":"Best open-source software"},"328":{"id":"/concepts/principles-13","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#simplicity","content":"Minimal languages and setup (npm, TypeScript and SQL)"},"329":{"id":"/concepts/principles-14","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#simplicity","content":"Minimal dependencies"},"330":{"id":"/concepts/principles-15","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#simplicity","content":"Single-purpose examples and templates"},"331":{"id":"/concepts/principles-16","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#simplicity","content":"Detailed documentation"},"332":{"id":"/concepts/principles-17","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#simplicity","content":"Total transparency"},"333":{"id":"/concepts/principles-18","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#extensibility","content":"Every manufacturer has unique needs that are not covered by the standard platform. We want to make it easy to extend the platform to meet their needs."},"334":{"id":"/concepts/principles-19","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#extensibility","content":"To provide extensibility we have the following goals:"},"335":{"id":"/concepts/principles-20","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#extensibility","content":"Easy to add custom applications"},"336":{"id":"/concepts/principles-21","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#extensibility","content":"Easy to add API endpoints"},"337":{"id":"/concepts/principles-22","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#extensibility","content":"Easy to add custom database tables"},"338":{"id":"/concepts/principles-23","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#extensibility","content":"Easy to add modules and interfaces to the primary application"},"339":{"id":"/concepts/principles-24","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#openness","content":"The ERP system is the heart of a business' digital operation. We want to make sure that they can easily integrate with other systems and customize it in any way that they need. The only real way to do this that to make the source code available."},"340":{"id":"/concepts/principles-25","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#openness","content":"An open source ERP system has a number of benefits, including:"},"341":{"id":"/concepts/principles-26","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#openness","content":"Lower costs"},"342":{"id":"/concepts/principles-27","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#openness","content":"Greater flexibility"},"343":{"id":"/concepts/principles-28","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#openness","content":"Better security"},"344":{"id":"/concepts/principles-29","page_id":"/concepts/principles","tags":[],"type":"text","url":"/concepts/principles#productivity","content":"When making decisions, we aim to optimize for long-term developer productivity. We take it as a given that everyone wants more features. But in order to quickly provide new features over time, we need to make sure that the platform is easy to use and maintain. This may mean that we have a steeper learning curve in the short term, but it should pay off in the long term."},"345":{"id":"/concepts/realtime","page_id":"/concepts/realtime","type":"page","content":"Realtime","breadcrumbs":["Framework","Concepts"],"tags":[],"url":"/concepts/realtime"},"346":{"id":"/concepts/realtime-0","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime","content":"Learn about syncing data in realtime in Carbon"},"347":{"id":"/concepts/realtime-1","page_id":"/concepts/realtime","type":"heading","tags":[],"url":"/concepts/realtime#listening-for-async-events-to-complete","content":"Listening for async events to complete"},"348":{"id":"/concepts/realtime-2","page_id":"/concepts/realtime","type":"heading","tags":[],"url":"/concepts/realtime#minimizing-the-number-of-requests-for-popular-data","content":"Minimizing the number of requests for popular data"},"349":{"id":"/concepts/realtime-3","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime","content":"There are two basic use cases for realtime data in Carbon ERP:"},"350":{"id":"/concepts/realtime-4","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime","content":"Listening for async events to complete"},"351":{"id":"/concepts/realtime-5","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime","content":"Minimizing the number of requests for popular data"},"352":{"id":"/concepts/realtime-6","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime#listening-for-async-events-to-complete","content":"When a user performs an action that triggers an async event (a job is inserted into a queue), the UI should listen for updates to the table to be updated."},"353":{"id":"/concepts/realtime-7","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime#listening-for-async-events-to-complete","content":"This can be done easily with the useRealtime hook:"},"354":{"id":"/concepts/realtime-8","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime#listening-for-async-events-to-complete","content":"A smaller subset of the table can be listened to by passing a second argument. Here we listen for the rows with an id of 1, 2, or 3:"},"355":{"id":"/concepts/realtime-9","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime#listening-for-async-events-to-complete","content":"Whenever a row is updated, the data for the page will be re-fetched."},"356":{"id":"/concepts/realtime-10","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime#minimizing-the-number-of-requests-for-popular-data","content":"Some data like the list of parts, customers, and suppliers are used on many pages. And regularly refetching thousands of rows is not ideal. To avoid making a request for this data on every page, we load it once in the <RealtimeDataProvider> on page load. We then put the data from each table into a nanostore hook that has a getter and setter that can be accessed from any page. For example:"},"357":{"id":"/concepts/realtime-11","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime#minimizing-the-number-of-requests-for-popular-data","content":"Without realtime, this data would quickly become stale. To keep data fresh, the <RealtimeDataProvider> listens for updates to the table and update the nanostore hook accordingly. This means that the data will be updated on every page that uses the hook."},"358":{"id":"/concepts/realtime-12","page_id":"/concepts/realtime","tags":[],"type":"text","url":"/concepts/realtime#minimizing-the-number-of-requests-for-popular-data","content":"Here is the basic pattern for listening to updates to a table in the <RealtimeDataProvider> component and updating the store:"},"359":{"id":"/concepts/traceability","page_id":"/concepts/traceability","type":"page","content":"Traceability","breadcrumbs":["Framework","Concepts"],"tags":[],"url":"/concepts/traceability"},"360":{"id":"/concepts/traceability-0","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability","content":"Learn about the traceability system in Carbon"},"361":{"id":"/concepts/traceability-1","page_id":"/concepts/traceability","type":"heading","tags":[],"url":"/concepts/traceability#core-tables","content":"Core Tables"},"362":{"id":"/concepts/traceability-2","page_id":"/concepts/traceability","type":"heading","tags":[],"url":"/concepts/traceability#trackedentity","content":"trackedEntity"},"363":{"id":"/concepts/traceability-3","page_id":"/concepts/traceability","type":"heading","tags":[],"url":"/concepts/traceability#trackedactivity","content":"trackedActivity"},"364":{"id":"/concepts/traceability-4","page_id":"/concepts/traceability","type":"heading","tags":[],"url":"/concepts/traceability#bridge-tables-trackedactivityinput--trackedactivityoutput","content":"Bridge Tables: trackedActivityInput & trackedActivityOutput"},"365":{"id":"/concepts/traceability-5","page_id":"/concepts/traceability","type":"heading","tags":[],"url":"/concepts/traceability#graph-construction","content":"Graph Construction"},"366":{"id":"/concepts/traceability-6","page_id":"/concepts/traceability","type":"heading","tags":[],"url":"/concepts/traceability#graph-structure","content":"Graph Structure"},"367":{"id":"/concepts/traceability-7","page_id":"/concepts/traceability","type":"heading","tags":[],"url":"/concepts/traceability#graph-traversal","content":"Graph Traversal"},"368":{"id":"/concepts/traceability-8","page_id":"/concepts/traceability","type":"heading","ta